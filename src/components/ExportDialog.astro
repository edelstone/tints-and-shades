---
import InlineIcon from "./InlineIcon.astro";

const formats = [
  { id: "hex", label: "Hex" },
  { id: "hex-hash", label: "#Hex" },
  { id: "rgb", label: "RGB" },
  { id: "css", label: "CSS" },
  { id: "json", label: "JSON" },
];
---

<dialog id="export-dialog" class="utility-dialog export-dialog" aria-labelledby="export-title" aria-modal="true">
  <div class="utility-dialog-header">
    <h2 id="export-title" class="utility-dialog-title">Export palettes</h2>
    <button id="export-close" class="utility-dialog-close" type="button" aria-label="Close export dialog">
      <span aria-hidden="true"><InlineIcon name="x" /></span>
    </button>
  </div>
  <div class="export-tabs" role="tablist" aria-label="Export format">
    {
      formats.map((format, index) => {
        const isActive = index === 0;
        return (
          <button
            class={`export-tab${isActive ? " is-active" : ""}`}
            type="button"
            role="tab"
            aria-selected={isActive ? "true" : "false"}
            aria-controls="export-output"
            id={`export-tab-${format.id}`}
            data-format={format.id}
            tabindex={isActive ? undefined : "-1"}
          >
            {format.label}
          </button>
        );
      })
    }
  </div>
  <div class="export-body" id="export-panels">
    <pre class="export-output language-none" id="export-output" role="tabpanel" aria-labelledby="export-tab-hex" tabindex="-1">
      <code class="export-output-code language-none" />
    </pre>
  </div>
  <div class="export-copy utility-copy-wrapper">
    <button id="export-copy" class="utility-copy-button export-copy-button" type="button" aria-label="Copy export">
      <span class="copy-indicator copy-indicator-copy" aria-hidden="true"><InlineIcon name="copy" /></span>
      <span class="copy-indicator copy-indicator-check" aria-hidden="true"><InlineIcon name="check" /></span>
    </button>
    <div id="export-copy-status" class="sr-only" aria-live="polite"></div>
  </div>
</dialog>
