{
  "name": "tints-and-shades",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "description": "Easily make tints and shades that match the output of Chrome DevTools, Sass, Less, and PostCSS.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "watch:readme": "nodemon --watch src/shared/about.html --watch build-readme.js --exec \"npm run build:readme\"",
    "build:readme": "node build-readme.js",
    "dev": "npm run build:readme && astro dev",
    "build": "npm run build:api && npm run build:readme && astro build",
    "start": "concurrently \"npm run watch:readme\" \"npm run dev\"",
    "build:api": "npm --workspace @edelstone/tints-and-shades run build",
    "test:api": "npm --workspace @edelstone/tints-and-shades run test",
    "test:app": "node --test test/*.test.mjs"
  },
  "keywords": [
    "colors",
    "hex",
    "tints",
    "shades",
    "palettes",
    "design"
  ],
  "author": "Michael Edelstone <michael.edelstone@gmail.com> (https://michaeledelstone.com)",
  "license": "MIT",
  "dependencies": {
    "@edelstone/tints-and-shades": "file:packages/tints-and-shades",
    "@melloware/coloris": "^0.25.0",
    "color-name-list": "^14.40.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "astro": "^7.0.0",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14",
    "sass": "^1.101.0",
    "turndown": "^7.2.4"
  }
}
